# ── YouTube Data API v3 ──────────────────────────────
# Google Cloud Console で発行したキー（CLI・Web 共通でサーバ側のみ使用）
YOUTUBE_API_KEY=ここにAPIキーを貼り付け

# ── Web アプリ（backend）用 ─────────────────────────
# ログイン用の共有パスワード
APP_PASSWORD=好きなパスワード
# トークン署名鍵（長いランダム文字列にする）
SECRET_KEY=change-me-to-a-long-random-string
# 1日のクオータ上限ガード（概算ユニット。無料枠は10,000）
DAILY_QUOTA_CAP=8000
# 本番デプロイ時のみ：フロント(Vercel)のURL。ローカルでは空でOK
FRONTEND_ORIGIN=
